# Required. Used to sign session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Required for the AI reading aids (questions, definitions, translations)
ANTHROPIC_API_KEY=

# Absolute path to the directory holding EPUB files.
# Defaults to ./books/ relative to the project root if unset.
BOOK_DIR=
